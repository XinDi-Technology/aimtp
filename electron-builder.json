{
  "appId": "com.aimtp.converter",
  "productName": "Aimtp",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "src/fonts/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "src/fonts",
      "to": "dist/renderer/fonts"
    }
  ],
  "extraMetadata": {
    "main": "dist/main/main/main.js"
  },
  "win": { 
    "target": "nsis"
  },
  "mac": { 
    "target": "dmg"
  },
  "linux": { 
    "target": "AppImage"
  },
  "publish": null
}
